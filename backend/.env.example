# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# AI Prediction
GROQ_API_KEY="your-groq-api-key"

# Email Alerts
# Recipient of breach-risk alerts (required for any email to send)
ALERT_RECIPIENT_EMAIL="ops-team@example.com"

# Option A — Resend (HTTPS API). REQUIRED in production / on hosts that block
# outbound SMTP (e.g. Railway free/hobby plans). If set, this is used instead
# of Gmail SMTP. Get a key at https://resend.com.
RESEND_API_KEY=""
RESEND_FROM="Eluno OMS <onboarding@resend.dev>"

# Option B — Gmail SMTP (local dev fallback, used only when RESEND_API_KEY is empty)
GMAIL_USER="your-gmail@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"

# App
PORT=3000