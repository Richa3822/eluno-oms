generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id             String   @id @default(uuid())
  customerName   String
  storeLocation  String
  prescription   Json
  frameId        String?
  lensType       String   // SINGLE_VISION, PROGRESSIVE, BIFOCAL
  lensIndex      String   // 1.50, 1.56, 1.61, 1.67, 1.74
  coating        String   // AR, BLUE_CUT, PHOTOCHROMIC, NONE
  status         String   @default("ORDER_PLACED")
  slaDeadline    DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  statusLogs     OrderStatusLog[]
  breachAlerts   BreachAlert[]
}

model OrderStatusLog {
  id          String   @id @default(uuid())
  orderId     String
  fromStatus  String?
  toStatus    String
  reason      String?
  updatedBy   String   @default("system")
  createdAt   DateTime @default(now())

  order       Order    @relation(fields: [orderId], references: [id])
}

model LensInventory {
  id          String   @id @default(uuid())
  powerSph    Float
  powerCyl    Float    @default(0)
  powerAxis   Int      @default(0)
  lensType    String
  lensIndex   String
  coating     String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model SlaConfig {
  id          String   @id @default(uuid())
  lensType    String   @unique
  tatHours    Int
}

model BreachAlert {
  id                String    @id @default(uuid())
  orderId           String
  predictedBreachAt DateTime
  alertSentAt       DateTime?
  channel           String?
  breachRisk        String?
  riskReason        String?
  createdAt         DateTime  @default(now())

  order             Order     @relation(fields: [orderId], references: [id])
}